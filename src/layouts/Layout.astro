---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bruno de Souza Farias — Desenvolvedor Full Stack Web',
  description = 'Portfolio profissional de Bruno de Souza Farias - Desenvolvedor Full Stack Web com experiência em HTML5, CSS3, JavaScript, React e Node.js.',
} = Astro.props;

const siteUrl = 'https://brunosouzafarias.github.io';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="desenvolvedor web, full stack, frontend, backend, HTML5, CSS3, JavaScript, React, Node.js, portfolio, Bruno Souza, Trybe, Anhanguera, cibersegurança"
    />
    <meta name="author" content="Bruno de Souza Farias" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/assets/img/about.jpg`} />
    <meta property="og:site_name" content="Bruno Souza - Portfolio" />
    <meta property="og:locale" content="pt_BR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={siteUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/assets/img/about.jpg`} />

    <script type="application/ld+json">
      {JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Bruno de Souza Farias',
        jobTitle: 'Desenvolvedor Web Full Stack',
        url: siteUrl,
        image: `${siteUrl}/assets/img/about.jpg`,
        sameAs: [
          'https://www.linkedin.com/in/bruno-souza-farias/',
          'https://github.com/BrunoSouzaFarias',
          'https://www.instagram.com/brusf13/',
          'https://twitter.com/dgkkcs',
        ],
        skills: ['React', 'Node.js', 'SQL', 'Docker', 'AWS', 'HTML5', 'CSS3', 'JavaScript', 'ITIL', 'Scrum'],
        email: 'brunodesouzafarias@yahoo.com.br',
      })}
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <script is:inline>
      (function () {
        var saved = localStorage.getItem('portfolio-theme');
        var theme = saved === 'dark' || saved === 'light'
          ? saved
          : window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
