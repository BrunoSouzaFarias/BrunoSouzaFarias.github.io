---
import { contactInfo } from '../data/profile';
---

<section class="hero" id="home">
  <canvas id="particle-canvas" class="hero__canvas" aria-hidden="true"></canvas>

  <div class="container hero__content">
    <p class="label-mono hero__label">// full_stack_developer</p>
    <h1 class="hero__title">
      Olá, eu sou o<br />
      <span class="hero__title-accent">Bruno</span>
    </h1>
    <p class="hero__subtitle">
      Desenvolvedor Full Stack construindo produtos sólidos com React, Node.js e atenção real aos detalhes.
    </p>

    <div class="hero__actions">
      <a href="#contact" class="btn">Falar comigo</a>
      <a href="/assets/cv/bruno-souza-cv.html" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
        ↓ Baixar CV
      </a>
    </div>

    <div class="hero__social">
      <a href={`mailto:${contactInfo.email}`} title="Email" aria-label="Email">✉</a>
      <a href={contactInfo.linkedin} target="_blank" rel="noopener noreferrer" title="LinkedIn" aria-label="LinkedIn">in</a>
      <a href={contactInfo.github} target="_blank" rel="noopener noreferrer" title="GitHub" aria-label="GitHub">gh</a>
    </div>
  </div>

  <div class="hero__scroll-hint" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 72px;
  }

  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__content {
    position: relative;
    z-index: 2;
  }

  .hero__label {
    margin-bottom: 1rem;
  }

  .hero__title {
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .hero__title-accent {
    color: var(--accent);
    text-shadow: 0 0 40px var(--border);
  }

  .hero__subtitle {
    max-width: 520px;
    color: var(--text-muted);
    font-size: 1.1rem;
    margin: 1.5rem 0 2.5rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero__social {
    display: flex;
    gap: 1rem;
  }
  .hero__social a {
    width: 42px;
    height: 42px;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    transition: border-color var(--transition), transform var(--transition);
  }
  .hero__social a:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .hero__scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 24px;
    height: 40px;
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    z-index: 2;
  }
  .hero__scroll-hint span {
    display: block;
    width: 4px;
    height: 8px;
    background: var(--accent);
    border-radius: 2px;
    margin: 6px auto;
    animation: scrollHint 1.8s ease-in-out infinite;
  }
  @keyframes scrollHint {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(16px); opacity: 0; }
  }
</style>
