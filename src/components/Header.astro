---
---

<header class="header">
  <nav class="nav container">
    <a href="#home" class="nav__logo label-mono">BRUNO_SOUZA<span>.dev</span></a>

    <div class="nav__menu" id="nav-menu">
      <ul class="nav__list">
        <li><a href="#home" class="nav__link">Home</a></li>
        <li><a href="#stack" class="nav__link">Stack</a></li>
        <li><a href="#work" class="nav__link">Work</a></li>
        <li><a href="#contact" class="nav__link">Contato</a></li>
      </ul>
    </div>

    <div class="nav__actions">
      <button id="about-trigger" class="btn btn--ghost nav__about-btn">Sobre mim</button>
      <button id="themeToggle" class="nav__theme-toggle" aria-label="Mudar tema">☾</button>
      <button id="nav-toggle" class="nav__toggle" aria-label="Abrir menu">☰</button>
    </div>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 75%, transparent);
    border-bottom: 1px solid var(--glass-border);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .nav__logo {
    font-size: 0.95rem;
    color: var(--text);
  }
  .nav__logo span {
    color: var(--accent);
  }

  .nav__list {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color var(--transition);
    position: relative;
  }
  .nav__link:hover,
  .nav__link.active {
    color: var(--accent);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav__about-btn {
    padding: 0.5rem 1rem;
    font-size: 0.78rem;
  }

  .nav__theme-toggle,
  .nav__toggle {
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--accent);
    width: 38px;
    height: 38px;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color var(--transition);
  }
  .nav__theme-toggle:hover,
  .nav__toggle:hover {
    border-color: var(--accent);
  }

  .nav__toggle {
    display: none;
  }

  @media (max-width: 720px) {
    .nav__menu {
      position: fixed;
      top: 72px;
      left: 0;
      right: 0;
      background: var(--bg-elevated);
      border-bottom: 1px solid var(--glass-border);
      transform: translateY(-110%);
      transition: transform var(--transition);
      padding: 1.5rem 0;
    }
    .nav__menu.show {
      transform: translateY(0);
    }
    .nav__list {
      flex-direction: column;
      align-items: center;
      gap: 1.25rem;
    }
    .nav__toggle {
      display: flex;
    }
    .nav__about-btn {
      padding: 0.5rem 0.7rem;
      font-size: 0.7rem;
    }
  }
</style>
