---
import { contactInfo } from '../data/profile';
---

<section class="contact container" id="contact">
  <p class="label-mono">// contato</p>
  <h2 class="section-title">Vamos conversar?</h2>
  <p class="contact__intro">Aberto a oportunidades de trabalho e projetos freelance.</p>

  <div class="contact__grid">
    <form class="contact__form glass" id="contactForm">
      <input type="text" placeholder="Seu nome" class="contact__input" id="contactName" required aria-label="Nome" />
      <input type="email" placeholder="Seu email" class="contact__input" id="contactEmail" required aria-label="Email" />
      <textarea placeholder="Sua mensagem" id="contactMessage" rows="6" class="contact__input" required aria-label="Mensagem"></textarea>
      <p id="contactFeedback" class="contact__feedback" role="status"></p>
      <button type="submit" class="btn">Enviar mensagem</button>
    </form>

    <div class="contact__direct glass">
      <p class="label-mono">Contato direto</p>
      <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
      <a href={contactInfo.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn →</a>
      <a href={contactInfo.github} target="_blank" rel="noopener noreferrer">GitHub →</a>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 6rem 24px 8rem;
  }
  .contact__intro {
    color: var(--text-muted);
    margin-bottom: 3rem;
  }
  .contact__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2rem;
  }
  .contact__form {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact__input {
    background: transparent;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }
  .contact__input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .contact__feedback {
    min-height: 1.2rem;
    font-size: 0.85rem;
    margin: 0;
  }
  .contact__feedback--success {
    color: var(--success);
  }
  .contact__feedback--error {
    color: var(--danger);
  }
  .contact__direct {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .contact__direct a {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  @media (max-width: 720px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
