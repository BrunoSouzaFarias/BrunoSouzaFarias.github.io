  JavaScript: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><path d="M9 16a2 2 0 0 0 2-2V9H9" /><path d="M14 9h2v2a2 2 0 0 1-2 2h-1.5a2 2 0 0 0-2 2v1" /></svg>`,
  HTML5: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 5l1.5 14 7.5 3 7.5-3L21 5L12 2z"/><path d="M17 9H9.5L10 12h7l-.5 5-4.5 1.5-4.5-1.5-.2-2.5"/></svg>`,
  CSS3: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 5l1.5 14 7.5 3 7.5-3L21 5L12 2z"/><path d="M16.5 9H9l.3 3h7.2l-.5 4.5-4 1.5-4-1.5V15"/></svg>`,
  "Node.js": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 7v10l9 5 9-5V7L12 2z"/><path d="M12 22V12M12 12L3 7M12 12l9-5M3 17l9 5 9-5"/></svg>`,
  SQL: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 11v6c0 1.66 4 3 9 3s9-1.34 9-3v-6"/></svg>`,
  AWS: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19c1.4-1.1 2.5-2.7 2.5-4.5A5.5 5.5 0 0 0 14.5 9h-1A5.5 5.5 0 0 0 8 14.5c0 1.8 1.1 3.4 2.5 4.5"/><path d="M6 16c-2 0-3-1.5-3-3s1.5-3 3-3h.5C7.2 7 9.8 5 13 5c3.5 0 6.5 2.5 7 6h.5c1.5 0 2.5 1 2.5 2.5s-1.5 2.5-3 2.5"/><path d="M7 20c3 1.5 7 1.5 10 0" stroke-width="1.5"/></svg>`,
  Docker: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.5c0 2-2 3.5-5 3.5H5.5C2.5 15 .5 13 .5 11s2.5-4 5.5-4c2 0 3 .5 4 1"/><rect x="6" y="9" width="3" height="2" rx="0.5"/><rect x="10" y="9" width="3" height="2" rx="0.5"/><rect x="8" y="6" width="3" height="2" rx="0.5"/><path d="M17 11.5c0-1.5 1.5-2.5 3-2.5" /></svg>`,
  ITIL: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 11l2 2 4-4"/></svg>`,
  Scrum: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l.73-1.19"/></svg>`,
  Kanban: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="5" height="18" rx="1"/><rect x="10" y="3" width="5" height="12" rx="1"/><rect x="17" y="3" width="5" height="15" rx="1"/></svg>`,
  Jira: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14l6-6 4 4 6-6"/><circle cx="20" cy="6" r="1"/><circle cx="10" cy="8" r="1"/><circle cx="14" cy="12" r="1"/><circle cx="4" cy="14" r="1"/></svg>`
};
---

<section class="stack container" id="stack">
  <CircuitLines variant="section" />
  <p class="label-mono">// stack</p>
  <h2 class="section-title">Com o que eu trabalho</h2>
  <p class="stack__intro">Ferramentas e práticas que uso no dia a dia para entregar produtos sólidos.</p>

  <div class="stack__grid" data-reveal-group>
    {stack.map((category) => (
      <div class="stack__category glass reveal">
        <p class="label-mono stack__category-label">{category.label}</p>
        <ul class="stack__items">
          {category.items.map((item) => (
            <li>
              <span class="stack__badge">
                {icons[item.name] ? (
                  <Fragment set:html={icons[item.name]} />
                ) : (
                  item.name.charAt(0)
                )}
              </span>
              {item.name}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
  .stack {
    position: relative;
    padding: 6rem 24px;
  }
  .stack__intro {
    color: var(--text-muted);
    margin-bottom: 3rem;
  }
  .stack__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .stack__category {
    position: relative;
    overflow: hidden;
    padding: 1.5rem;
    transition: border-color var(--transition), transform var(--transition);
    --x: 50%;
    --y: 50%;
  }
  .stack__category:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
  }
  .stack__category::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 300ms ease;
    background: radial-gradient(240px circle at var(--x) var(--y), color-mix(in srgb, var(--accent) 18%, transparent), transparent 70%);
  }
  .stack__category:hover::before,
  .stack__category:focus-visible::before {
    opacity: 1;
  }
  .stack__category-label,
  .stack__items {
    position: relative;
    z-index: 1;
  }
  .stack__category-label {
    margin-bottom: 1.25rem;
  }
  .stack__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .stack__items li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.92rem;
  }
  .stack__badge {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--glass-border);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--glass-bg);
  }
  .stack__badge svg {
    width: 16px;
    height: 16px;
  }
</style>

